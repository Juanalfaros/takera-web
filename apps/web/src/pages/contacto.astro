---
import Layout from "../layouts/Layout.astro";

const l = "es";

const dict = {
    seoTitle: "Contacto | Takera Pro",
    seoDesc:
        "Ponte en contacto con Takera Pro. Estamos listos para suministrar tortillas de la mejor calidad a tu restaurante o negocio en Miami.",
    title: "Contacto",
    subtitle: "¿Listo para elevar la calidad de tus tortillas?",
    formTitle: "Envíanos un mensaje",
    name: "Nombre completo",
    email: "Correo electrónico",
    company: "Empresa / Restaurante",
    message: "Mensaje",
    submit: "Enviar mensaje",
    infoTitle: "Información de contacto",
    address: "Dirección",
    phone: "Teléfono",
    emailLabel: "Email",
    hours: "Horario de atención",
    hoursVal: "Lunes a Viernes: 8:00 AM - 5:00 PM",
};
---

<Layout title={dict.seoTitle} description={dict.seoDesc}>
    <div class="contact-page">
        <div class="page-header">
            <div class="container">
                <h1>{dict.title}</h1>
                <p>{dict.subtitle}</p>
            </div>
        </div>

        <div class="container">
            <div class="contact-grid">
                <div class="contact-info">
                    <div class="info-card">
                        <h3>{dict.infoTitle}</h3>

                        <div class="info-item">
                            <i class="ph ph-map-pin"></i>
                            <div>
                                <strong>{dict.address}</strong>
                                <p>Miami, Florida, United States</p>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="ph ph-phone"></i>
                            <div>
                                <strong>{dict.phone}</strong>
                                <p>+1 (XXX) XXX-XXXX</p>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="ph ph-envelope"></i>
                            <div>
                                <strong>{dict.emailLabel}</strong>
                                <p>ventas@takera.us</p>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="ph ph-clock"></i>
                            <div>
                                <strong>{dict.hours}</strong>
                                <p>{dict.hoursVal}</p>
                            </div>
                        </div>
                    </div>

                    <div class="map-placeholder">
                        <div class="map-overlay">
                            <i class="ph ph-map-trifold"></i>
                            <span>Miami, FL</span>
                        </div>
                    </div>
                </div>

                <div class="contact-form">
                    <div class="form-container">
                        <h3>{dict.formTitle}</h3>
                        <form action="/gracias" method="POST">
                            <div class="form-group">
                                <label for="name">{dict.name}</label>
                                <input
                                    type="text"
                                    id="name"
                                    name="name"
                                    required
                                    placeholder="Ej. Juan Pérez"
                                />
                            </div>

                            <div class="form-group">
                                <label for="email">{dict.email}</label>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    placeholder="tu@email.com"
                                />
                            </div>

                            <div class="form-group">
                                <label for="company">{dict.company}</label>
                                <input
                                    type="text"
                                    id="company"
                                    name="company"
                                    placeholder="Nombre de tu negocio"
                                />
                            </div>

                            <div class="form-group">
                                <label for="message">{dict.message}</label>
                                <textarea
                                    id="message"
                                    name="message"
                                    rows="5"
                                    required
                                    placeholder="¿En qué podemos ayudarte?"
                                ></textarea>
                            </div>

                            <button type="submit" class="btn-submit">
                                {dict.submit}
                                <i class="ph ph-paper-plane-tilt"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .contact-page {
        background-color: var(--color-surface);
        padding-bottom: 6rem;
    }
    .page-header {
        padding: 6rem 0 4rem;
        background-color: var(--color-bg);
        border-bottom: 1px solid var(--color-decor);
        text-align: center;
        margin-bottom: 4rem;
    }
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }
    h1 {
        font-size: 3.5rem;
        color: var(--color-primary);
        margin-bottom: 1rem;
    }
    .page-header p {
        font-size: 1.25rem;
        color: #555;
        max-width: 600px;
        margin: 0 auto;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 4rem;
        align-items: start;
    }

    .info-card {
        background: var(--color-bg);
        padding: 2.5rem;
        border: 1px solid var(--color-decor);
        margin-bottom: 2rem;
    }
    .info-card h3 {
        font-size: 1.5rem;
        margin-bottom: 2rem;
        color: var(--color-primary);
    }
    .info-item {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .info-item i {
        font-size: 1.5rem;
        color: var(--color-accent);
        margin-top: 0.25rem;
    }
    .info-item strong {
        display: block;
        font-size: 0.9rem;
        color: #888;
        text-transform: uppercase;
        margin-bottom: 0.25rem;
    }
    .info-item p {
        color: var(--color-primary);
        font-weight: 500;
    }

    .map-placeholder {
        height: 300px;
        background: #eee;
        border: 1px solid var(--color-decor);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }
    .map-overlay {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        color: #aaa;
    }
    .map-overlay i {
        font-size: 3rem;
    }

    .form-container {
        background: var(--color-bg);
        padding: 3rem;
        border: 1px solid var(--color-decor);
        box-shadow: 15px 15px 0px var(--color-accent);
    }
    .form-container h3 {
        font-size: 2rem;
        margin-bottom: 2rem;
        color: var(--color-primary);
    }
    .form-group {
        margin-bottom: 1.5rem;
    }
    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: var(--color-primary);
    }
    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 1rem;
        border: 1px solid var(--color-decor);
        background: var(--color-surface);
        font-family: inherit;
        font-size: 1rem;
        transition: border-color 0.2s;
    }
    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--color-accent);
    }

    .btn-submit {
        width: 100%;
        padding: 1rem;
        background: var(--color-primary);
        color: #fff;
        border: none;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        cursor: pointer;
        transition: opacity 0.2s;
    }
    .btn-submit:hover {
        opacity: 0.9;
    }

    @media (max-width: 968px) {
        .contact-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        h1 {
            font-size: 2.5rem;
        }
    }
</style>
