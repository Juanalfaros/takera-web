---
import { Image } from "astro:assets";
import logoTakeraWhite from "../assets/logos/logo-takera-white.svg";
import { localizePath } from "../utils/i18n";
const currentYear = new Date().getFullYear();

const l = Astro.currentLocale || "es";
const isEn = l === "en";

const dict = {
    es: {
        tagline: "Producción a gran escala. Calidad artesanal insuperable.",
        company: "Compañía",
        about: "Nosotros",
        catalog: "Catálogo B2B",
        orders: "Pedidos de Fábrica",
        legal: "Legal",
        privacy: "Privacidad",
        terms: "Términos de Servicio",
        contact: "Contacto",
        rights: "Takera Pro. Todos los derechos reservados.",
        designedBy: "Diseñado y desarrollado con ♥ por",
        agency: "tu agencia Zutra",
        location: "Miami, Florida, EE.UU.",
    },
    en: {
        tagline: "Large-scale production. Unbeatable artisanal quality.",
        company: "Company",
        about: "About Us",
        catalog: "B2B Catalog",
        orders: "Factory Orders",
        legal: "Legal",
        privacy: "Privacy Policy",
        terms: "Terms of Service",
        contact: "Contact",
        rights: "Takera Pro. All rights reserved.",
        designedBy: "Designed and developed with ♥ by",
        agency: "your agency Zutra",
        location: "Miami, Florida, USA.",
    },
}[l as "es" | "en"] || {
    tagline: "Producción a gran escala. Calidad artesanal insuperable.",
    company: "Compañía",
    about: "Nosotros",
    catalog: "Catálogo B2B",
    orders: "Pedidos de Fábrica",
    legal: "Legal",
    privacy: "Privacidad",
    terms: "Términos de Servicio",
    contact: "Contacto",
    rights: "Takera Pro. Todos los derechos reservados.",
    designedBy: "Diseñado y desarrollado con ♥ por",
    agency: "tu agencia Zutra",
    location: "Miami, Florida, EE.UU.",
};
---

<footer class="footer">
    <div class="container">
        <div class="footer-grid">
            <!-- Columna Marca -->
            <div class="footer-brand">
                <div class="logo-container">
                    <a href={localizePath("/", l)} class="footer-logo">
                        <Image
                            src={logoTakeraWhite}
                            alt="Takera Logo"
                            height={100}
                            width={180}
                            style="width: auto; height: 100px;"
                        />
                    </a>
                </div>
                <p class="footer-tagline">
                    {dict.tagline}
                </p>
                <div class="social-links">
                    <a href="#" aria-label="Instagram"
                        ><i class="ph ph-instagram-logo"></i></a
                    >
                    <a href="#" aria-label="LinkedIn"
                        ><i class="ph ph-linkedin-logo"></i></a
                    >
                    <a href="#" aria-label="WhatsApp"
                        ><i class="ph ph-whatsapp-logo"></i></a
                    >
                </div>
            </div>

            <!-- Columna Navegación -->
            <div class="footer-nav">
                <div class="footer-col">
                    <h3>{dict.company}</h3>
                    <ul>
                        <li>
                            <a href={isEn ? "/en/#nosotros" : "/#nosotros"}
                                >{dict.about}</a
                            >
                        </li>
                        <li>
                            <a href={isEn ? "/en/catalog" : "/catalogo"}
                                >{dict.catalog}</a
                            >
                        </li>
                        <li>
                            <a href={isEn ? "/en/contact" : "/contacto"}
                                >{dict.orders}</a
                            >
                        </li>
                    </ul>
                </div>

                <div class="footer-col">
                    <h3>{dict.legal}</h3>
                    <ul>
                        <li>
                            <a href={isEn ? "/en/#privacidad" : "/#privacidad"}
                                >{dict.privacy}</a
                            >
                        </li>
                        <li>
                            <a href={isEn ? "/en/#terminos" : "/#terminos"}
                                >{dict.terms}</a
                            >
                        </li>
                    </ul>
                </div>

                <div class="footer-col contact-col">
                    <h3>{dict.contact}</h3>
                    <ul>
                        <li>
                            <a href="mailto:ventas@takera.us"
                                ><i class="ph ph-envelope-simple"></i> ventas@takera.us</a
                            >
                        </li>
                        <li>
                            <a href="tel:+13055550199"
                                ><i class="ph ph-phone"></i> +1 (305) 555-0199</a
                            >
                        </li>
                        <li>
                            <span
                                ><i class="ph ph-map-pin"></i>
                                {dict.location}</span
                            >
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="bottom-content">
                <p>&copy; {currentYear} {dict.rights}</p>
                <p class="zutra-credit">
                    {dict.designedBy}
                    <a
                        href="https://zutra.agency/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="zutra-link">{dict.agency}</a
                    >
                </p>
            </div>
        </div>
    </div>
</footer>

<style>
    .footer {
        background-color: var(--color-primary);
        color: var(--color-bg);
        padding: 5rem 0 0 0;
        font-family: var(--font-body);
        border-top: 4px solid var(--color-accent);
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* GRID PRINCIPAL */
    .footer-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 4rem;
        padding-bottom: 4rem;
    }

    /* BLOQUE MARCA */
    .footer-brand {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .footer-tagline {
        font-size: 1.1rem;
        line-height: 1.6;
        color: rgba(255, 249, 240, 0.7);
        max-width: 320px;
    }

    .social-links {
        display: flex;
        gap: 1.25rem;
        margin-top: 0.5rem;
    }

    .social-links a {
        color: var(--color-bg);
        font-size: 1.5rem;
        transition:
            transform 0.2s ease,
            color 0.2s ease;
    }

    .social-links a:hover {
        color: var(--color-accent);
        transform: translateY(-3px);
    }

    /* NAVEGACIÓN */
    .footer-nav {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    .footer-col h3 {
        color: var(--color-accent);
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.1em;
        margin-bottom: 1.5rem;
        font-family: var(--font-heading);
    }

    .footer-col ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .footer-col a,
    .footer-col span {
        color: rgba(255, 249, 240, 0.8);
        text-decoration: none;
        font-size: 0.95rem;
        transition: color 0.2s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .footer-col a:hover {
        color: var(--color-accent);
    }

    .contact-col i {
        color: var(--color-accent);
        font-size: 1.1rem;
    }

    /* BOTTOM BAR */
    .footer-bottom {
        border-top: 1px solid rgba(255, 249, 240, 0.1);
        padding: 2.5rem 0;
    }

    .bottom-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        color: rgba(255, 249, 240, 0.5);
        font-size: 0.85rem;
    }

    /* CRÉDITO ZUTRA */
    /* .zutra-credit {
        font-style: italic;
    } */

    .zutra-link {
        color: var(--color-accent);
        text-decoration: none;
        font-weight: 600;
        transition: opacity 0.2s ease;
    }

    .zutra-link:hover {
        opacity: 0.8;
        text-decoration: underline;
    }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
        .footer-grid {
            gap: 2rem;
        }
    }

    @media (max-width: 900px) {
        .footer-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        .footer-brand {
            text-align: center;
            align-items: center;
        }
        .footer-tagline {
            margin: 0 auto;
        }
        .social-links {
            justify-content: center;
        }
        .footer-nav {
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }
    }

    @media (max-width: 768px) {
        .footer-nav {
            grid-template-columns: repeat(2, 1fr);
            gap: 3rem 1.5rem;
        }
        .contact-col {
            grid-column: span 2;
        }
        .footer-col h3 {
            margin-bottom: 1rem;
        }
        .bottom-content {
            flex-direction: column;
            text-align: center;
            gap: 1.5rem;
        }
    }

    @media (max-width: 480px) {
        .footer-nav {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .footer-col a,
        .footer-col span {
            justify-content: center;
        }
        .contact-col {
            grid-column: span 1;
        }
        .footer {
            padding: 4rem 0 0 0;
        }
    }
</style>
