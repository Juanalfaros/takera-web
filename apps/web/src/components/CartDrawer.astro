---
// CartDrawer.astro — Cajón lateral del carrito de cotizaciones
const l = Astro.currentLocale || "es";

const dictSource = {
    es: {
        title: "Tu Cotización",
        empty: "Tu cotización está vacía.",
        catalog: "Ver Catálogo",
        estimated: "Estimado",
        note: "El precio final se confirmará con nuestro equipo.",
        btnQuote: "Enviar Cotización",
        qtyRemove: "Quitar",
        qtyUnit: " / u",
        ariaClose: "Cerrar carrito",
    },
    en: {
        title: "Your Quote",
        empty: "Your quote is empty.",
        catalog: "View Catalog",
        estimated: "Estimated",
        note: "Final price will be confirmed by our team.",
        btnQuote: "Submit Quote",
        qtyRemove: "Remove",
        qtyUnit: " / ea",
        ariaClose: "Close cart",
    },
};

const dict = dictSource[l as "es" | "en"] || dictSource.es;
---

<!-- Overlay -->
<div id="cart-overlay" class="cart-overlay" aria-hidden="true"></div>

<!-- Drawer -->
<aside
    id="cart-drawer"
    class="cart-drawer"
    aria-label={dict.title}
    aria-hidden="true"
    data-locale={l}
    data-dict-remove={dict.qtyRemove}
    data-dict-unit={dict.qtyUnit}
>
    <div class="drawer-header">
        <h2><i class="ph ph-shopping-cart"></i> {dict.title}</h2>
        <button id="close-cart" aria-label={dict.ariaClose}>
            <i class="ph ph-x"></i>
        </button>
    </div>

    <div id="cart-body" class="drawer-body">
        <!-- Items se renderizan via JS -->
        <div class="empty-cart" id="empty-cart-msg">
            <i class="ph ph-package"></i>
            <p>{dict.empty}</p>
            <a href={l === "en" ? "/en/#soluciones" : "/#soluciones"}
                >{dict.catalog}</a
            >
        </div>
        <ul id="cart-items-list" class="cart-items-list"></ul>
    </div>

    <div id="cart-footer" class="drawer-footer" style="display:none">
        <div class="cart-total">
            <span>{dict.estimated}</span>
            <strong id="cart-total-price">$0</strong>
        </div>
        <p class="cart-note">
            {dict.note}
        </p>
        <a
            href={l === "en" ? "/en/cotizacion" : "/cotizacion"}
            class="btn-quote"
        >
            {dict.btnQuote}
            <i class="ph ph-arrow-right"></i>
        </a>
    </div>
</aside>

<style>
    .cart-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 200;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }
    .cart-overlay.open {
        opacity: 1;
        pointer-events: all;
    }

    .cart-drawer {
        position: fixed;
        top: 0;
        right: 0;
        height: 100dvh;
        width: 420px;
        max-width: 95vw;
        background: var(--color-surface, #fff);
        border-left: 2px solid var(--color-decor, #e0e0e0);
        z-index: 1201;
        display: flex;
        flex-direction: column;
        transform: translateX(100%);
        transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: -4px 0 32px rgba(0, 0, 0, 0.12);
    }
    .cart-drawer.open {
        transform: translateX(0);
    }

    .drawer-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--color-decor, #e0e0e0);
    }
    .drawer-header h2 {
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-primary, #111);
    }
    .drawer-header h2 i {
        font-size: 1.3rem;
        color: var(--color-accent, #d97706);
    }
    #close-cart {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.4rem;
        color: #888;
        display: flex;
        align-items: center;
        transition: color 0.2s;
    }
    #close-cart:hover {
        color: var(--color-primary, #111);
    }

    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1rem 1.5rem;
    }

    .empty-cart {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        height: 100%;
        color: #aaa;
        text-align: center;
        padding: 3rem 0;
    }
    .empty-cart i {
        font-size: 3.5rem;
        opacity: 0.3;
    }
    .empty-cart a {
        color: var(--color-accent, #d97706);
        font-weight: 600;
        text-decoration: none;
    }
    .empty-cart a:hover {
        text-decoration: underline;
    }

    .cart-items-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0;
        padding: 0;
        margin: 0;
    }
</style>

<style is:global>
    .cart-item {
        display: grid;
        grid-template-columns: 64px 1fr auto;
        gap: 0.75rem;
        align-items: center;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--color-decor, #e0e0e0);
    }
    .cart-item-image {
        width: 64px;
        height: 64px;
        object-fit: cover;
        border: 1px solid var(--color-decor, #e0e0e0);
        background: #f5f5f5;
    }
    .cart-item-image.placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ccc;
        font-size: 1.5rem;
    }
    .cart-item-info {
        min-width: 0;
    }
    .cart-item-name {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--color-primary, #111);
        margin-bottom: 0.25rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .cart-item-price {
        font-size: 0.85rem;
        color: var(--color-accent, #d97706);
        font-weight: 700;
    }

    .cart-item-controls {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
    }
    .qty-controls {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        border: 1px solid var(--color-decor, #e0e0e0);
    }
    .qty-btn {
        background: none;
        border: none;
        width: 26px;
        height: 26px;
        cursor: pointer;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-primary, #111);
        transition: background 0.15s;
    }
    .qty-btn:hover {
        background: var(--color-decor, #e0e0e0);
    }
    .qty-value {
        min-width: 24px;
        text-align: center;
        font-weight: 700;
        font-size: 0.9rem;
    }
    .remove-btn {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 0.75rem;
        color: #aaa;
        text-decoration: underline;
        padding: 0;
    }
    .remove-btn:hover {
        color: #e53e3e;
    }

    .drawer-footer {
        padding: 1.25rem 1.5rem;
        border-top: 2px solid var(--color-decor, #e0e0e0);
        background: var(--color-bg, #f9f9f9);
    }
    .cart-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.25rem;
        font-size: 0.95rem;
    }
    .cart-total strong {
        font-size: 1.4rem;
        color: var(--color-accent, #d97706);
    }
    .cart-note {
        font-size: 0.78rem;
        color: #999;
        margin-bottom: 1rem;
    }
    .btn-quote {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        padding: 0.9rem;
        background: var(--color-primary, #111);
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: opacity 0.2s;
    }
    .btn-quote:hover {
        opacity: 0.85;
    }
</style>

<style is:global>
    .cart-total strong {
        font-size: 1.4rem;
        color: var(--color-accent, #d97706);
    }
</style>

<script>
    import {
        cartItems,
        removeFromCart,
        updateQuantity,
    } from "../stores/cart.ts";

    function formatPrice(price: number) {
        return `$${price.toFixed(2)}`;
    }

    function renderCart() {
        const items = cartItems.get();
        const drawerEl = document.getElementById("cart-drawer")!;
        const list = document.getElementById("cart-items-list")!;
        const emptyMsg = document.getElementById("empty-cart-msg")!;
        const footer = document.getElementById("cart-footer")!;
        const totalEl = document.getElementById("cart-total-price")!;

        const dictRemove = drawerEl.dataset.dictRemove || "Quitar";
        const dictUnit = drawerEl.dataset.dictUnit || " / u";

        list.innerHTML = "";

        if (items.length === 0) {
            emptyMsg.style.display = "flex";
            footer.style.display = "none";
            return;
        }

        emptyMsg.style.display = "none";
        footer.style.display = "block";

        let total = 0;

        items.forEach((item: any) => {
            total += item.price * item.quantity;

            const li = document.createElement("li");
            li.className = "cart-item";
            li.innerHTML = `
                ${
                    item.imageUrl
                        ? `<img class="cart-item-image" src="${item.imageUrl}" alt="${item.name}" />`
                        : `<div class="cart-item-image placeholder"><i class="ph ph-image"></i></div>`
                }
                <div class="cart-item-info">
                    <div class="cart-item-name">${item.name}</div>
                    <div class="cart-item-price">${formatPrice(item.price)}${dictUnit}</div>
                </div>
                <div class="cart-item-controls">
                    <div class="qty-controls">
                        <button class="qty-btn" data-action="dec" data-id="${item.id}"><i class="ph ph-minus"></i></button>
                        <span class="qty-value">${item.quantity}</span>
                        <button class="qty-btn" data-action="inc" data-id="${item.id}"><i class="ph ph-plus"></i></button>
                    </div>
                    <button class="remove-btn" data-action="remove" data-id="${item.id}">${dictRemove}</button>
                </div>
            `;
            list.appendChild(li);
        });

        totalEl.textContent = formatPrice(total);
    }

    function updateBadge() {
        const count = cartItems
            .get()
            .reduce((s: number, i: any) => s + i.quantity, 0);
        document.querySelectorAll(".cart-badge").forEach((el) => {
            el.textContent = String(count);
            (el as HTMLElement).style.display = count > 0 ? "flex" : "none";
        });
    }

    // Delegación de eventos en la lista
    document
        .getElementById("cart-items-list")!
        .addEventListener("click", (e) => {
            const btn = (e.target as HTMLElement).closest(
                "[data-action]",
            ) as HTMLButtonElement | null;
            if (!btn) return;
            const id = btn.dataset.id!;
            const action = btn.dataset.action!;
            const item = cartItems.get().find((i: any) => i.id === id);
            if (!item) return;

            if (action === "inc") updateQuantity(id, item.quantity + 1);
            if (action === "dec") updateQuantity(id, item.quantity - 1);
            if (action === "remove") removeFromCart(id);
        });

    // Abrir/cerrar drawer
    const drawer = document.getElementById("cart-drawer")!;
    const overlay = document.getElementById("cart-overlay")!;

    function openCart() {
        drawer.classList.add("open");
        overlay.classList.add("open");
        drawer.setAttribute("aria-hidden", "false");
    }
    function closeCart() {
        drawer.classList.remove("open");
        overlay.classList.remove("open");
        drawer.setAttribute("aria-hidden", "true");
    }

    document.getElementById("close-cart")!.addEventListener("click", closeCart);
    overlay.addEventListener("click", closeCart);

    // El botón del Header dispara este evento
    document.addEventListener("open-cart", openCart);

    // Suscripción reactiva al store
    cartItems.subscribe(() => {
        renderCart();
        updateBadge();
    });

    // Render inicial
    renderCart();
    updateBadge();
</script>
