---
const l = Astro.currentLocale || "es";

const dict = {
    es: {
        subtitle: "Confían en nuestra calidad para escalar sus operaciones",
    },
    en: {
        subtitle: "They trust our quality to scale their operations",
    },
}[l as "es" | "en"] || {
    subtitle: "Confían en nuestra calidad para escalar sus operaciones",
};
---

<section class="trusted-section">
    <div class="container">
        <p class="subtitle">
            {dict.subtitle}
        </p>
        <div class="logo-grid">
            <!-- Placeholders para logos reales. Usando iconos o texto por ahora -->
            <div class="logo-item">
                <i class="ph ph-fork-knife"></i>
                <span>Gourmet Group</span>
            </div>
            <div class="logo-item">
                <i class="ph ph-storefront"></i>
                <span>Mercado Fresh</span>
            </div>
            <div class="logo-item">
                <i class="ph ph-pizza"></i>
                <span>Cantina Central</span>
            </div>
            <div class="logo-item">
                <i class="ph ph-hamburger"></i>
                <span>Burger Co.</span>
            </div>
            <div class="logo-item">
                <i class="ph ph-cooking-pot"></i>
                <span>Chef's Choice</span>
            </div>
        </div>
    </div>
</section>

<style>
    .trusted-section {
        background-color: var(--color-bg);
        padding: 4rem 0;
        border-bottom: 1px solid var(--color-decor);
    }
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        text-align: center;
    }
    .subtitle {
        font-family: var(--font-body);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #666;
        margin-bottom: 2.5rem;
    }
    .logo-grid {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 2rem;
        opacity: 0.6; /* Efecto silencioso para las marcas */
        filter: grayscale(100%);
        transition: opacity 0.3s ease;
    }
    .logo-grid:hover {
        opacity: 1;
    }
    .logo-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-text);
        font-weight: 700;
        font-size: 1.1rem;
        transition:
            transform 0.2s ease,
            color 0.2s ease;
    }
    .logo-item i {
        font-size: 2.5rem;
    }
    .logo-item:hover {
        transform: translateY(-5px);
        color: var(--color-green);
    }

    @media (max-width: 768px) {
        .logo-grid {
            justify-content: center;
        }
        .logo-item {
            width: calc(33% - 1rem);
        }
    }
    @media (max-width: 480px) {
        .logo-item {
            width: calc(50% - 1rem);
        }
    }
</style>
