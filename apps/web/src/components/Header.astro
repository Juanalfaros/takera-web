---
import { Image } from "astro:assets";
import logoTakera from "../assets/logos/logo-takera.svg";

const l = Astro.currentLocale || "es";

const dict = {
    es: {
        shipping: "Envío gratis a todo Miami en pedidos sobre $500",
        catalog: "Catálogo",
        about: "Nosotros",
        order: "Hacer Pedido",
        cartLabel: "Cotización en curso",
    },
    en: {
        shipping: "Free shipping across Miami on orders over $500",
        catalog: "Catalog",
        about: "About Us",
        order: "Order Now",
        cartLabel: "Current Quote",
    },
}[l as "es" | "en"] || {
    shipping: "Envío gratis a todo Miami en pedidos sobre $500",
    catalog: "Catálogo",
    about: "Nosotros",
    order: "Hacer Pedido",
    cartLabel: "Cotización en curso",
};

const otherLocale = l === "es" ? "en" : "es";

import { localizePath, getToggleLocalePath } from "../utils/i18n";
const otherLocalePath = getToggleLocalePath(Astro.url);
---

<header class="header">
    <!-- Topbar B2B -->
    <div class="topbar">
        <div class="topbar-container">
            <div class="topbar-left">
                <i class="ph ph-truck"></i>
                {dict.shipping}
            </div>
            <div class="topbar-right">
                <!-- Selector de Idioma -->
                <a href={otherLocalePath} class="lang-switch">
                    <i class="ph ph-globe"></i>
                    {otherLocale.toUpperCase()}
                </a>
                <span class="divider">|</span>
                <a href="tel:+13055550199" title="+1 (305) 555-0199">
                    <i class="ph ph-phone"></i>
                    <span class="contact-label">+1 (305) 555-0199</span>
                </a>
                <span class="divider">|</span>
                <a href="mailto:ventas@takera.us" title="ventas@takera.us">
                    <i class="ph ph-envelope-simple"></i>
                    <span class="contact-label">ventas@takera.us</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Main Nav -->
    <div class="main-nav">
        <div class="container">
            <!-- Izquierda: Navegación (Desktop) -->
            <nav class="nav-left desktop-only">
                <ul>
                    <li>
                        <a
                            href={l === "en"
                                ? localizePath("/catalog", l)
                                : localizePath("/catalogo", l)}
                        >
                            <i class="ph ph-package"></i>
                            {dict.catalog}
                        </a>
                    </li>
                    <li>
                        <a href={localizePath("/#nosotros", l)}>
                            <i class="ph ph-buildings"></i>
                            {dict.about}
                        </a>
                    </li>
                </ul>
            </nav>

            <!-- Centro: Logo Colgante -->
            <a href={localizePath("/", l)} class="logo-link">
                <Image
                    src={logoTakera}
                    alt="Takera Logo"
                    height={80}
                    width={80}
                />
            </a>

            <!-- Derecha: Acciones y Carrito -->
            <nav class="nav-right">
                <ul>
                    <li class="desktop-only">
                        <a
                            href={l === "en"
                                ? localizePath("/contact", l)
                                : localizePath("/contacto", l)}
                            class="btn-primary"
                        >
                            {dict.order}
                            <i class="ph ph-arrow-right"></i>
                        </a>
                    </li>
                    <li>
                        <button
                            class="cart-btn"
                            id="header-cart-btn"
                            aria-label={dict.cartLabel}
                        >
                            <i class="ph ph-shopping-cart"></i>
                            <span class="cart-badge" style="display:none"
                                >0</span
                            >
                        </button>
                    </li>
                    <li class="mobile-only">
                        <button
                            class="menu-toggle"
                            id="menu-toggle"
                            aria-label="Toggle Menu"
                        >
                            <i class="ph ph-list"></i>
                        </button>
                    </li>
                </ul>
            </nav>
        </div>
    </div>

    <!-- Mobile Menu Overlay -->
    <div class="mobile-menu" id="mobile-menu">
        <div class="mobile-menu-header">
            <Image src={logoTakera} alt="Takera Logo" height={50} width={50} />
            <button class="close-menu" id="close-menu">
                <i class="ph ph-x"></i>
            </button>
        </div>
        <nav class="mobile-nav-links">
            <ul>
                <li>
                    <a
                        href={l === "en"
                            ? localizePath("/catalog", l)
                            : localizePath("/catalogo", l)}
                    >
                        <i class="ph ph-package"></i>
                        {dict.catalog}
                    </a>
                </li>
                <li>
                    <a href={localizePath("/#nosotros", l)}>
                        <i class="ph ph-buildings"></i>
                        {dict.about}
                    </a>
                </li>
                <li>
                    <a
                        href={l === "en"
                            ? localizePath("/contact", l)
                            : localizePath("/contacto", l)}
                        class="mobile-cta"
                    >
                        {dict.order}
                        <i class="ph ph-arrow-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</header>

<script>
    const menuToggle = document.getElementById("menu-toggle");
    const closeMenu = document.getElementById("close-menu");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-nav-links a");

    menuToggle?.addEventListener("click", () => {
        mobileMenu?.classList.add("show");
        document.body.style.overflow = "hidden";
    });

    closeMenu?.addEventListener("click", () => {
        mobileMenu?.classList.remove("show");
        document.body.style.overflow = "";
    });

    mobileLinks.forEach((link) => {
        link.addEventListener("click", () => {
            mobileMenu?.classList.remove("show");
            document.body.style.overflow = "";
        });
    });

    document
        .getElementById("header-cart-btn")
        ?.addEventListener("click", () => {
            document.dispatchEvent(new CustomEvent("open-cart"));
        });
</script>

<style>
    .header {
        position: sticky;
        top: 0;
        z-index: 1000;
        width: 100%;
        font-family: var(--font-heading);
    }

    /* UTILITIES */
    .desktop-only {
        display: flex;
    }
    .mobile-only {
        display: none;
    }

    @media (max-width: 900px) {
        .desktop-only {
            display: none;
        }
        .mobile-only {
            display: flex;
        }
    }

    /* TOPBAR */
    .topbar {
        background-color: var(--color-primary);
        color: var(--color-surface);
        padding: 0.5rem 0;
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.5px;
    }
    .topbar-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .topbar-left {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .topbar-left i {
        color: var(--color-green);
        font-size: 1.1rem;
    }
    .topbar-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .topbar a {
        color: var(--color-surface);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        transition: color 0.2s ease;
    }
    .topbar a:hover {
        color: var(--color-accent);
    }
    .topbar a i {
        color: var(--color-accent);
    }
    .lang-switch {
        font-weight: 700;
        cursor: pointer;
    }
    .divider {
        color: rgba(255, 255, 255, 0.2);
    }

    /* MAIN NAV */
    .main-nav {
        background-color: var(--color-surface);
        border-bottom: 2px solid var(--color-decor);
        height: 70px;
        position: relative;
    }
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        height: 100%;
        position: relative;
    }

    /* Central Logo */
    .logo-link {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        top: 0;
        background-color: var(--color-surface);
        padding: 0.75rem 1rem;
        border: 2px solid var(--color-decor);
        border-top: none;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 101;
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }
    .logo-link:hover {
        transform: translate(-50%, 4px);
        box-shadow: 4px 4px 0px var(--color-accent);
    }

    /* Navegaciones Laterales */
    .nav-left ul,
    .nav-right ul {
        display: flex;
        list-style: none;
        gap: 2rem;
        align-items: center;
    }
    .nav-left {
        grid-column: 1;
        justify-self: start;
    }
    .nav-right {
        grid-column: 3;
        justify-self: end;
    }

    /* Enlaces */
    .nav-left a,
    .nav-right a {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: var(--color-text);
        font-weight: 600;
        transition: color 0.2s ease;
    }
    .nav-left a:hover,
    .nav-right a:not(.btn-primary):hover {
        color: var(--color-accent);
    }
    i.ph {
        font-size: 1.25rem;
    }

    /* Botón Principal */
    .btn-primary {
        background-color: var(--color-accent);
        color: var(--color-surface);
        padding: 0.5rem 1.5rem;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: background-color 0.2s ease;
    }
    .btn-primary:hover {
        background-color: var(--color-primary);
        color: var(--color-surface);
    }

    /* Carrito & Toggle */
    .cart-btn,
    .menu-toggle {
        background: transparent;
        border: none;
        cursor: pointer;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-text);
        transition: color 0.2s ease;
    }
    .cart-btn:hover,
    .menu-toggle:hover {
        color: var(--color-accent);
    }
    .cart-btn i,
    .menu-toggle i {
        font-size: 1.75rem;
    }
    .cart-badge {
        position: absolute;
        top: -5px;
        right: -8px;
        background-color: var(--color-accent);
        color: var(--color-surface);
        font-size: 0.7rem;
        font-weight: bold;
        height: 18px;
        width: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    /* MOBILE MENU OVERLAY */
    .mobile-menu {
        position: fixed;
        top: 0;
        right: -100%;
        width: 100%;
        height: 100vh;
        background-color: var(--color-surface);
        z-index: 200;
        transition: right 0.3s ease;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }
    .mobile-menu.show {
        right: 0;
    }
    .mobile-menu-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .close-menu {
        background: none;
        border: none;
        font-size: 2rem;
        color: var(--color-primary);
        cursor: pointer;
    }
    .mobile-nav-links ul {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }
    .mobile-nav-links a {
        text-decoration: none;
        color: var(--color-primary);
        font-size: 1.5rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .mobile-cta {
        background-color: var(--color-accent);
        color: #fff !important;
        padding: 1rem;
        justify-content: center;
        border-radius: 4px;
        text-transform: uppercase;
    }

    @media (max-width: 900px) {
        .topbar-container {
            padding: 0 1rem;
        }
        .topbar-left {
            display: none;
        }
        .contact-label {
            display: none;
        }
        .container {
            grid-template-columns: 1fr auto auto;
            gap: 1rem;
        }
        .logo-link {
            left: 1rem;
            transform: translateX(0);
            padding: 0.5rem 0.75rem;
        }
        .logo-link:hover {
            transform: translateY(4px);
        }
        .nav-right {
            justify-self: end;
        }
        .nav-right ul {
            gap: 1rem;
        }
    }
</style>
